{
  "$schema": "https://raw.githubusercontent.com/victor-falcon/falcode/main/internal/config/themes/schema.json",
  "defs": {
    "purple":       "#7B61FF",
    "purple_light":  "#5B41DF",
    "gold":          "#FFD700",
    "gold_light":    "#A07800",
    "red":           "#FF6B6B",
    "red_light":     "#CC2222",
    "white":         "#FFFFFF",
    "dark_bg":       "#1E1E2E",
    "dark_bar":      "#13131F",
    "dark_inner_bg": "#0D0D1A",
    "dark_sep":      "#333355",
    "dark_sheet_bg": "#1A1A2E",
    "light_bg":      "#F0F0F8",
    "light_bar":     "#E2E2F0",
    "light_inner_bg":"#ECECF8",
    "light_sep":     "#C8C8E8",
    "light_sheet_bg":"#F8F8FF",
    "muted_dark":    "#888888",
    "muted_light":   "#666666",
    "desc_dark":     "#CCCCCC",
    "desc_light":    "#444444",
    "green":         "#5FFF87",
    "green_light":   "#00AA44",
    "orange":        "#FF8C00",
    "orange_light":  "#C05800",
    "agent_red":     "#FF5F5F",
    "purple_tab":           "#5B4CC0",
    "purple_ws_dim":        "#2E2480",
    "purple_pale":          "#CBC5FF",
    "purple_pale_fg":       "#3D2E8C",
    "purple_ws_dim_fg":     "#B0A8F0",
    "purple_ws_dim_light":  "#9080D8",
    "purple_pale_light":    "#EAE6FF",
    "purple_pale_fg_light": "#4A38B8"
  },
  "theme": {
    "workspace_active":      { "dark": "purple",         "light": "purple_light"  },
    "workspace_inactive":    { "dark": "purple_ws_dim",    "light": "purple_ws_dim_light" },
    "workspace_active_fg":   { "dark": "white",            "light": "white"               },
    "workspace_inactive_fg": { "dark": "purple_ws_dim_fg", "light": "white"               },
    "workspace_bar_bg":      { "dark": "transparent",    "light": "transparent"   },
    "workspace_border":      { "dark": "purple",         "light": "purple_light"  },
    "prefix_indicator_fg":   { "dark": "gold",           "light": "gold_light"    },
    "status_fg":             { "dark": "red",            "light": "red_light"     },
    "inner_active":          { "dark": "purple_tab",      "light": "purple"              },
    "inner_inactive":        { "dark": "purple_pale",     "light": "purple_pale_light"   },
    "inner_active_fg":       { "dark": "white",           "light": "white"               },
    "inner_inactive_fg":     { "dark": "purple_pale_fg",  "light": "purple_pale_fg_light"},
    "inner_bar_bg":          { "dark": "transparent",    "light": "transparent"   },
    "inner_separator":       { "dark": "dark_sep",       "light": "light_sep"     },
    "new_tab_btn_bg":        { "dark": "dark_bg",        "light": "light_bg"      },
    "new_tab_btn_fg":        { "dark": "muted_dark",     "light": "muted_light"   },
    "new_workspace_btn_bg":  { "dark": "dark_bg",        "light": "light_bg"      },
    "new_workspace_btn_fg":  { "dark": "muted_dark",     "light": "muted_light"   },
    "sheet_bg":              { "dark": "dark_sheet_bg",  "light": "light_sheet_bg"},
    "sheet_border":          { "dark": "purple",         "light": "purple_light"  },
    "sheet_title":           { "dark": "gold",           "light": "gold_light"    },
    "sheet_key":             { "dark": "purple",         "light": "purple_light"  },
    "sheet_description":     { "dark": "desc_dark",      "light": "desc_light"    },
    "sheet_group":           { "dark": "gold",           "light": "gold_light"    },
    "sheet_separator":       { "dark": "dark_sep",       "light": "light_sep"     },
    "footer_bg":             { "dark": "transparent",    "light": "transparent"   },
    "agent_working_fg":      { "dark": "green",          "light": "green_light"   },
    "agent_permission_fg":   { "dark": "agent_red",      "light": "red_light"     },
    "agent_question_fg":     { "dark": "orange",         "light": "orange_light"  },
    "agent_done_fg":         { "dark": "green",          "light": "green_light"   }
  }
}
